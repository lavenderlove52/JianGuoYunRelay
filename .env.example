# 复制为 `.env` 后填写真实值；`cargo run` 会自动加载项目根目录下的 `.env`（不覆盖已在 shell 里设置的变量）。
# 勿将 `.env` 提交到 Git（仓库已 `.gitignore` 忽略）。

# 监听地址（默认 0.0.0.0:8080）
LISTEN_ADDR=127.0.0.1:8080

# 对外「金库」URL 路径（M2 固定单文件，默认 /vault.kdbx）
RELAY_VAULT_PATH=/yourfolder/your.kdbx

# 坚果云 WebDAV 根（须为 https，主机默认仅允许 dav.jianguoyun.com）
JGY_WEBDAV_ROOT=https://dav.jianguoyun.com/dav/
JGY_USERNAME=your_email@example.com
JGY_APP_PASSWORD=your_app_password
JGY_REMOTE_PATH=/yourfolder/your.kdbx

# 可选：逗号分隔允许的上游主机名（覆盖默认）
# JGY_ALLOWED_HOSTS=dav.jianguoyun.com

# 公司端访问中继：Basic 与/或 Bearer（至少配一种）
RELAY_AUTH_USER=relay_user
# 密码不要带空格；引号可写可不写，写成 RELAY_AUTH_PASSWORD=secret 或 RELAY_AUTH_PASSWORD="secret" 均可（程序会去掉一层成对引号）
RELAY_AUTH_PASSWORD=relay_password
# RELAY_BEARER_TOKEN=

# PUT 必须带 If-Match 或 X-Base-ETag（默认 true；KeePass 联调可临时 false）
RELAY_REQUIRE_PUT_BASELINE=false

# 请求体上限（字节）
MAX_BODY_BYTES=33554432

CONNECT_TIMEOUT_SECS=10
UPSTREAM_TIMEOUT_SECS=120
